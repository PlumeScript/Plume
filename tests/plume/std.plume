/// Test join
@Table.join
  quill
  mark
end
/// Output
quillmark
/// End

/// Test join with sep
@Table.join(sep: \n)
  - quill
  - mark
end
/// Output
quill
mark
/// End

/// Test Table
let t = do
  - quill
  - mark
  quill: ink
end
$t[2], $t.quill
/// Output
mark, ink
/// End

/// Test type
$type($Table())\n
$type(nib)\n
$type($(1+1))
/// Output
table
string
number
/// End

/// Test seq 1
for write in seq(2, 5)
  $write
end
/// Output
2345
/// End

/// Test seq 2
for write in seq(3)
  $write
end
/// Output
123
/// End

/// Test seq 3
for write in seq(2, 6, 2)
  $write
end
/// Output
246
/// End

/// Test enumerate
let t = $Table(quill, wing, bird)
@Table.join(sep:\n)
  for index, value in enumerate(t)
    - Item $index is $value.
  end
end
/// Output
Item 1 is quill.
Item 2 is wing.
Item 3 is bird.
/// End

/// Test items
let t = $Table(first: quill, second: wing, bonus: bird)
@Table.join(sep:\n)
  for key, value in items(t)
    - Item "$key" is _($value)_.
  end
end
/// Output
Item "first" is _(quill)_.
Item "second" is _(wing)_.
Item "bonus" is _(bird)_.
/// End

/// Test items ?named
let t = $Table(wing: quill, write, song)
for k, v in items(t)
  $k → $v\n
end
---\n
for k, v in items(t, ?named)
  $k → $v\n
end
/// Output
wing → quill
1 → write
2 → song
---
wing → quill
/// End

/// Test numeric keys 1 (#253)
let t = do
  - Wing
  Write: Quill
  - Song
end

for k, v in items(t)
  $k → $v\n
end
/// Output
1 → Wing
Write → Quill
2 → Song
/// End

/// Test numeric keys 2 (#253)
let t = $Table()

set t[1] = Wing

for k, v in items(t)
  $k → $v\n
end
/// Output
1 → Wing
/// End

/// Test import text 1
$import(tests/plume/toimport/text)
/// Output
wings
/// End

/// Test import text 2
quill\n
$import(./tests/plume/toimport/text)\n
nib
/// Output
quill
wings
nib
/// End

/// Test import lib 1
let lib = $import(./tests/plume/toimport/lib)
$lib.nib
/// Output
quill
/// End

/// Test import lib 2
let infos = bird
let lib = $import(tests/plume/toimport/lib2)
$lib.wing() $infos
/// Output
blue quill bird
/// End

/// Test lua import
let double = $lua.require(tests/plume/toimport/lib)

$double(3)
/// Output
6
/// End

/// Test len
let t = do
  - Wing
  - Nib
  quill: blue
end
$len($t)
/// Output
2
/// End

/// Test Table append
let t = do
  - Wing
  - Nib
  quill: blue
end
$len($t)\n
$Table.append($t, paint)
$len($t)
/// Output
2
3
/// End

/// Test Table remove 1
let t = do
  - Wing
  - Nib
  quill: blue
end
$len($t)\n
$Table.remove($t)\n
$len($t)
/// Output
2
Nib
1
/// End

/// Test Table remove 2
let t = do
  - Wing
  - Nib
  quill: blue
end
$Table.remove($t)\n
$t[1]
/// Output
Nib
Wing
/// End

/// Test Table remove 3
let t = do
  Wing: Nib
  quill: blue
end
$Table.removeKey($t, Wing)\n
for k, v in items(t)
  $k
end
/// Output
quill
/// End

/// Test hasKey
let t = $Table(wing: nib)

$Table.hasKey($t, wing)\n
$Table.hasKey($t, nib)
/// Output
true
false
/// End

/// Test find
let t = $Table(wing: nib)

$Table.find($t, nib)
/// Output
wing
/// End

/// Test findAll
let t = $Table(wing: nib, write: nib)

$Table.join(...Table.findAll($t, nib))
/// Output
wingwrite
/// End

/// Test repr 1
$repr(5)
/// Output
5
/// End

/// Test repr 2
$repr(wing)
/// Output
wing
/// End

/// Test repr 3
$repr($empty)
/// Output
empty
/// End

/// Test repr 4
$repr($false)
/// Output
false
/// End

/// Test repr 5
$repr($repr)
/// Output
luaMacro<repr>
/// End

/// Test repr 6
macro Wing()
end

$repr($Wing)
/// Output
macro<Wing>
/// End

/// Test repr 7
@repr
  macro()
  end
end
/// Output
macro<???>
/// End

/// Test repr 8
let t = do
  Wing: macro()
  end
end
$repr($t.Wing)
/// Output
macro<Wing>
/// End

/// Test repr 9
let t = do
  - wing
  - nib
  color: blue
  - quill
end
$repr($t)
/// Output
$Table(wing, nib, color: blue, quill)
/// End

/// Test repr 10
let t = do
  - $empty
  color: macro()
  end
end
$repr($t)
/// Output
$Table(empty, color: macro<color>)
/// End

/// Test repr 11
let t = $Table()
macro Wing()
end

set t[Wing] = 5
$repr($t)
/// Output
$Table(macro<Wing>: 5)
/// End

/// Test repr 12
let t = do
  - wing
  sub: do
    - quill
    - nib
  end
end
$repr($t)
/// Output
$Table(wing, sub: $Table(quill, nib))
/// End

/// Test repr 13
let t = $Table()
set t[1] = $t
$repr($t)
/// Output
$Table($Table(...))
/// End

/// Test repr Table with holes 1
let t = $Table()
set t[1] = 5
set t[3]  = z
$repr($t)
/// Output
$Table(5, empty, z)
/// End

/// Test repr Table with holes 2
let t = $Table()
set t[1] = 5
set t[3000]  = z
$repr($t)
/// Output
$Table(5, 3000: z)
/// End

/// Test repr Table not ordered
let t = $Table()
set t[3]  = z
set t[1] = 5

$repr($t)
/// Output
$Table(3: z, 1: 5)
/// End

/// Test count
let t = $Table(wing: nib, write, nib)

$Table.count($t)\n
$Table.count($t, ?named)
/// Output
3
1
/// End

/// Test entry
let t = $Table(wing: nib, write: nib)

let k, v = $Table.entry($t, 2)
$k = $v
/// Output
write = nib
/// End

/// Test String on number
$type($String(5))
/// Output
string
/// End

/// Test copy 1
let t1 = (1, 2, 3)
let t2 = $Table.copy($t1)
set t2[1] = 0
$t1
/// Output
$Table(1, 2, 3)
/// End

/// Test copy 2
let t1 = ((1, 2, 3), 2, 3)
let t2 = $Table.copy($t1)
set t2[1][1] = 0
$t1
/// Output
$Table($Table(0, 2, 3), 2, 3)
/// End

/// Test deepcopy
let t1 = ((1, 2, 3), 2, 3)
let t2 = $Table.deepcopy($t1)
set t2[1][1] = 0
$t1
/// Output
$Table($Table(1, 2, 3), 2, 3)
/// End

/// Test nested deepcopy
let t1 = $Table()
set t1[1] = $t1
let t2 = $Table.deepcopy($t1)
$t2
/// Output
$Table($Table($Table(...)))
/// End