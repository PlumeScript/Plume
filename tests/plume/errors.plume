/// Test callstack
macro paint()
end

macro sing()
    $paint(1)
end

macro wing()
    $sing()
end

$wing()
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Wrong number of positional arguments for macro 'paint', 1 instead of 0.      │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ callstack                                                                   │
│    4  │macro sing()                                                            │
│    5  │    $paint(1)                                                           │
│       │     ^^^^^^^^                                                           │
│    6  │end                                                                     │
│                                                                                │
├────────────────────────────────────────────────────────────────────────────────┤
│ Traceback (most recent call first):                                            │
├────────────────────────────────────────────────────────────────────────────────┤
│  ↳ (same file)                                                                 │
│    8  │macro wing()                                                            │
│    9  │    $sing()                                                             │
│       │     ^^^^^^                                                             │
│                                                                                │
│  ↳ (same file)                                                                 │
│    12 │$wing()                                                                 │
│       │ ^^^^^^                                                                 │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

