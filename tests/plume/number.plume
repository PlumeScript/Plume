/// Test index number 1
$(1.5).floor()
/// Output
1
/// End

/// Test index number 2
let x = 1.5
$x.floor()
/// Output
1
/// End

/// Test index number 3
$Number.floor(1.5)
/// Output
1
/// End

/// Test ceil 1
$(1.52).ceil()
/// Output
2
/// End

/// Test ceil 2
$(1.52).ceil(digit: 1)
/// Output
1.6
/// End

/// Test floor 1
$(1.52).floor()
/// Output
1
/// End

/// Test floor 2
$(1.52).floor(digit: 1)
/// Output
1.5
/// End

/// Test round 1
$(1.54).round()
/// Output
2
/// End

/// Test round 2
$(1.54).round(digit: 1)
/// Output
1.5
/// End

/// Test clamp
for i in seq(5)
	$i.clamp(2, 4)\n
end
/// Output
2
2
3
4
4
/// End

/// Test format 1
$(1/3).format(%.2f)
/// Output
0.33
/// End

/// Test format 2
$(12).format(%05d)
/// Output
00012
/// End

/// Test sign
$(-5).sign()\n
$(7).sign()\n
$(0).sign()\n
/// Output
-1
1
0
/// End

/// Test local 1
$(5423.55).format(%s)
/// Output
5423.55
/// End

/// Test local 2
$(5325423.55875).format(%s, locale: en)
/// Output
5,325,423.55875
/// End

/// Test local 3
$(5325423.55875).format(%s, locale: fr)
/// Output
5 325 423,558 75
/// End

/// Test local 4
$(5325423.55875).format(%s, locale: custom, decimalSeparator: ??, thousandsSeparator:--)
/// Output
5--325--423??55875
/// End

/// Test local context 1
with locale: custom, localeDecimalSeparator: ??, localeThousandsSeparator:--
  Here is a number: $(5325423.55875)
end
/// Output
Here is a number: 5--325--423??55875
/// End

/// Test local context 2
with locale: custom, localeNumberFormat: <%020d>
  Here is a number: $(5325423.55875)
end
/// Output
Here is a number: <00000000000005325423>
/// End

/// Test localize
$(5325423.55875).localize(fr)
/// Output
5 325 423,558 75
/// End

