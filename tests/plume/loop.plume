/// Test iterator (next)
macro seq(a, b)
  state: $a
  stop: $b
  meta next: macro()
    if self.state <= self.stop
      $self.state
      set self.state += 1
    end
  end
end

for i in seq(1, 5)
  $i
end
/// Output
12345
/// End


/// Test iterator (iter)
let first5 = @table
  meta iter: macro()
    parent: $self
    state: 1
    meta next: macro()
      if self.state <= 5
        $self.state
        set self.state += 1
      end
    end
  end
end

for i in first5
  $i
end
/// Output
12345
/// End
