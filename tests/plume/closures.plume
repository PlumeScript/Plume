/// Test Capture "global"
let value = 5
macro Wing()
  $value
end
$Wing()
/// Output
5
/// End

/// Test Capture inside macro
macro makeClosure()
   let a = 10
   let b = 20
   macro ()
      $a$b
   end
end
let f = $makeClosure()
$f()
/// Output
1020
/// End


/// Test Capture nested scopes 1
macro makeClosure()
   let a = 10

   if true
      let b = 20
      macro ()
         $a$b
      end
   end
end
let f = $makeClosure()
$f()
/// Output
1020
/// End

/// Test Capture nested scopes 2
macro makeClosure()
   let a = 10
   let b = 20
   macro ()
      if true
         $a$b
      end
   end
end
let f = $makeClosure()
$f()
/// Output
1020
/// End


/// Test Mutation
macro makeCounter()
  let count = 0
  macro()
    set count += 1
    $count
  end
end

let counter = $makeCounter()
$counter()
$counter()
/// Output
12
/// End

/// Test Nested Macros 1
macro grandPa()
  let secret = GP
  
  macro()
    macro()
      $secret
    end
  end
end

let f = $grandPa()
$f()()
/// Output
GP
/// End

/// Test Nested Macros 2
macro grandPa()
  let secret = GP
  
  macro()
    macro()
      macro()
         $secret
      end
    end
  end
end

let f = $grandPa()
$f()()()
/// Output
GP
/// End

/// Test Setter getter
macro createBox()
  let value = 0
  _set: macro(v)
    set value = $v
  end
  _get: macro()
    $value
  end
end

let box = $createBox()
$box._set(42)
$box._get()
/// Output
42
/// End

/// Test rec
macro rec(n)
   if n==0
      macro(x)
         $x
      end
   else
      let f_rec = $rec($(n-1))
      macro(x)
         run $(print(x))
         $(n * f_rec(x))
      end
   end
end

let f = $rec(3)
$f(2)
/// Output
12
/// End