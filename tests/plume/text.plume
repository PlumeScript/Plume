/// Test escape in quotes 1
$("$")
/// Output
$
/// End

/// Test escape in quotes 2
$("a\ta")
/// Output
a	a
/// End

/// Test escape in quotes 3
$("\\")
/// Output
\
/// End

/// Test escape in quotes 4
$("\"")
/// Output
"
/// End

