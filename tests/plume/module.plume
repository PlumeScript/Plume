/// Test params 1
$import(tests/plume/toimport/param)
/// Output
10
/// End

/// Test params 2
$import(tests/plume/toimport/param, x: 5)
/// Output
5
/// End

/// Test use params
use tests/plume/toimport/useparam(x: 5)
$x
/// Output
5
/// End

/// Test params with cache
$import(tests/plume/toimport/param, x: 5)\n
$import(tests/plume/toimport/param)
/// Output
5
10
/// End

/// Test use params with cache
use tests/plume/toimport/useparam(x: 5)
$x\n
use tests/plume/toimport/useparam()
$x
/// Output
5
10
/// End

/// Test upvalue with cache
use tests/plume/toimport/inc
$inc()\n
$inc()\n
use tests/plume/toimport/inc
$inc()\n
$inc()\n
$inc()\n
/// Output
1
2
1
2
3
/// End

