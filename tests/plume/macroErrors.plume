/// Test not enought macro args
macro Wings(nib, quill, ink)
end
$Wings(paint, write)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Wrong number of positional arguments for macro 'Wings', 2 instead of 3.      │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ not enought macro args                                                      │
│    2 │end                                                                      │
│    3 │$Wings(paint, write)                                                     │
│      │ ^^^^^^^^^^^^^^^^^^^                                                     │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

/// Test to many macro args
macro Wings(nib, quill, ink)
end
$Wings(paint, write, sing, dance)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Wrong number of positional arguments for macro 'Wings', 4 instead of 3.      │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ to many macro args                                                          │
│    2 │end                                                                      │
│    3 │$Wings(paint, write, sing, dance)                                        │
│      │ ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^                                        │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

