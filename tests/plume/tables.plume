├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    2 │ let x                                                                   │
│    3 │ ref x: 5                                                                │
│      │ ^^^^^^^^                                                                │
│    4 │end                                                                      │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End