/// Test Table get indewrite
let t = $Table(mark, quill, ink)
$t[1]
/// Output
mark
/// End

/// Test Table set indewrite
let t = $Table(mark, quill, ink)
set t[1] = wing
$t[1]
/// Output
wing
/// End

/// Test Table write expand 1
let t1 = $Table(write, paint, make)

let t2 = do
	...t1
end

@Table.join(sep: \s)
	...t2
end
/// Output
write paint make
/// End

/// Test Table write expand 2
let t1 = $Table(write, paint, make)

let t2 = do
	- ink
	...t1
	- quill
end

@Table.join(sep: \s)
	...t2
end
/// Output
ink write paint make quill
/// End

/// Test Table write expand 3
let t1 = $Table(write: quill, paint: song)

let t2 = do
	...t1
end

$t2.write\n
$t2.paint
/// Output
quill
song
/// End

/// Test Table write expand 4
let t1 = $Table(write: quill, paint: song)

let t2 = do
	write: nib
	...t1
	paint: words
end

$t2.write\n
$t2.paint
/// Output
quill
words
/// End

/// Test Table ewritepand inline
let t = do
	- write
	- paint
	- song
	quill: mark
end

macro wing(write, paint, z, quill: word)
	$write - $paint - $z - $quill
end

$wing(...t)

/// Output
write - paint - song - mark
/// End

/// Test Table set
let t = do
	- write
	- paint
	- song
end
$t[1]\n
set t[1] = mark
$t[1]
/// Output
write
mark
/// End

/// Test safe index 1
let t = $Table(a:b)
$t.a?
$(t.a?)
/// Output
bb
/// End

/// Test safe index 2
let t = $Table(a:b)
$t.b?
$(t.b? or 1)
/// Output
1
/// End

/// Test safe index 3
let t = $Table(a:b)
$t["a"]?
$(t["a"]?)
/// Output
bb
/// End

/// Test safe index 4
let t = $Table(a:b)
$t["b"]?
$(t["b"]? or 1)
/// Output
1
/// End

/// Test dynamic keys 1
let x = wing
let t = do
	$x: nib
end

$t.wing
/// Output
nib
/// End

/// Test dynamic keys 2
let x = wing
let t = $Table($x: nib)

$t.wing
/// Output
nib
/// End

/// Test dynamic keys 3
let x = wing
let t = $(Table($x: "nib"))

$t.wing
/// Output
nib
/// End

/// Test ref 1
let t = do
	ref x: 1
	y: $x
end
$t.y
/// Output
1
/// End

/// Test ref 2
let t = do
	ref x: 1
	z: aaaa
	y: $x
end
$t.y
/// Output
1
/// End

/// Test ref 3
let t = do
	ref x: 1
	if true
		y: $x
	end
end
$t.y
/// Output
1
/// End

/// Test ref 4
let t = do
	ref x: 1
	y: $x$x$x
end
$t.y
/// Output
111
/// End

/// Test ref 5
let t = do
	ref x: 1
	y: @Table.join
		a$x\aaa
	end
end
$t.y
/// Output
a1aaa
/// End

/// Test ref  empty 1
let t = do
	ref x
	y: $x
end
$t.y
/// Output
/// End

/// Test ref  empty 2
let t = do
	ref x
	x: 5
	y: $x
end
$t.y
/// Output
5
/// End

/// Test ref change
let t = do
	ref x: 5
	x: $(x+1)
end
$t.x
/// Output
6
/// End

/// Test ref alias
let t = do
	ref x as z: 1
	y: @Table.join
		a$z\aaa
	end
end
$t.y
/// Output
a1aaa
/// End

/// Test inline Table
let t = (1, 2, a:b)
$t[1]$t.a
/// Output
1b
/// End

/// Test inline Table - eval
let t = $((1+2, 2, a:"b"))
$t[1]$t.a
/// Output
3b
/// End

/// Test inline Table nested
let t = (1, (1, 2), a:b)
$t[2][1]
/// Output
1
/// End

/// Test inline Table in call
$len((1, 2, 3))
/// Output
3
/// End

/// Test inline Table in call - eval
$(len((1, 2, 3)))
/// Output
3
/// End

/// Test inline Table as inline Table value 1
let t = (1, a:(1, 2))
$repr($t)
/// Output
(1, a: (1, 2))
/// End

/// Test inline Table as inline Table value 2
let t = (a:(1, 2))
$repr($t)
/// Output
(a: (1, 2))
/// End

/// Test inline Table as inline Table value 3
let t = $((1, a:(1, 2)))
$repr($t)
/// Output
(1, a: (1, 2))
/// End

/// Test inline Table in as named arg
macro wing(nib:$Table())
	$Table.join(...nib)
end

$wing(nib:(1, 2, 3))
/// Output
123
/// End

/// Test ref error
let t = do
	let x
	ref x: 5
end
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
