/// Test string+string
let _write = $String(1)
let paint = $String(1)
$(_write+paint)
/// Output
2
/// End

/// Test string+number
let _write = $String(1)
$(_write+1) // 1 is a number
/// Output
2
/// End

/// Test type convertion
let _write = $Table()
$type($_write)
/// Output
table
/// End

/// Test type convertion (if)
let _write = if 2==1+1
	$Table()
else
	$Table(write)
end
$type($_write)
/// Output
table
/// End

/// Test boolean 1
let bool = $(1==1)
Result\: $bool
/// Output
Result: true
/// End

/// Test boolean 2
let bool = $(1==1)
if bool
	Result\: true
end
/// Output
Result: true
/// End

