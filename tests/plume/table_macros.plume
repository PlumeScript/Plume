/// Test macro key
let t = do
  quill: macro()
    mark
  end
end
$t.quill()
/// Output
mark
/// End

/// Test macro item
let t = do
  - macro()
    mark
  end
end
$t[1]()
/// Output
mark
/// End

/// Test self by key
let t = do
  mark: song
  quill: macro()
     $self.mark
  end
end

$t.quill()
/// Output
song
/// End

/// Test self by index
let t = do
  mark: song
  - macro()
     $self.mark
  end
end

$t[1]()
/// Output
song
/// End

/// Test self chained
let obj = do
  wings: quill
  method1: macro()
    $self.wings
  end

  method2: macro()
    $self.method1()
  end
end

$obj.wings

/// Output
quill
/// End

/// Test block form Table
let t = do
    wing: macro(body)
        Write "$body"
    end
end

@t.wing
  paint the quill
end

/// Output
Write "paint the quill"
/// End