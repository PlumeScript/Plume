/// Test meta wrong parameter number 1
let t = @Table
  meta add: macro()
    $true
  end
end

$(t+1)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Wrong number of positional parameters for meta-macro 'add', 0 instead of 2.  │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    1 │let t = @Table                                                           │
│    2 │  meta add: macro()                                                      │
│      │  ^^^^^^^^^^^^^^^^^                                                      │
│    3 │    $true                                                                │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

/// Test meta wrong parameter number 2
let t = @Table
  meta add: macro(x, y, z)
    $true
  end
end

$(t+1)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Wrong number of positional parameters for meta-macro 'add', 3 instead of 2.  │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    1 │let t = @Table                                                           │
│    2 │  meta add: macro(x, y, z)                                               │
│      │  ^^^^^^^^^^^^^^^^^^^^^^^^                                               │
│    3 │    $true                                                                │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

/// Test meta wrong parameter number 3
let t = @Table
  meta add: macro(x, y, z: quill)
    $true
  end
end

$(t+1)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Meta-macro 'add' dont support named parameters.                              │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    1 │let t = @Table                                                           │
│    2 │  meta add: macro(x, y, z: quill)                                        │
│      │  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^                                        │
│    3 │    $true                                                                │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

/// Test meta wrong parameter number 4
let t = @Table
  meta call: macro(x, y, z: quill)
    $true
  end
end

$t(1)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Wrong number of positional arguments for macro '???', 1 instead of 2.        │
│   Usage: $<macro>(x, y, z: quill)                                              │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    5 │end                                                                      │
│    7 │$t(1)                                                                    │
│      │ ^^^^                                                                    │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

/// Test unknown meta
let t = @Table
  meta mymacro: macro()
  end
end
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → 'mymacro' isn't a valid meta-macro name.                                     │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    1 │let t = @Table                                                           │
│    2 │  meta mymacro: macro()                                                  │
│      │  ^^^^^^^^^^^^^^^^^^^^^                                                  │
│    3 │  end                                                                    │
│                                                                                │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End

/// Test stack overflow
let t = @Table
  meta addr: macro(x)
    $(self+1)
  end
end

$(t+1)
/// Error
╭────────────────────────────────────────────────────────────────────────────────╮
│ RUNTIME ERROR:                                                                 │
│ → Stack overflow                                                               │
├────────────────────────────────────────────────────────────────────────────────┤
│                                                                                │
│  ↳ test.plume                                                                  │
│    2 │meta addr: macro(x)                                                      │
│    3 │  $(self+1)                                                              │
│      │    ^^^^^^                                                               │
│    4 │end                                                                      │
│                                                                                │
├────────────────────────────────────────────────────────────────────────────────┤
│ Traceback (most recent call first):                                            │
├────────────────────────────────────────────────────────────────────────────────┤
│  ↳ (same file)                                                                 │
│    2 │meta addr: macro(x)                                                      │
│    3 │  $(self+1)                                                              │
│      │    ^^^^^^                                                               │
│                                                                                │
│  ↳...                                                                          │
│  ↳(previous block is repeated 998 more times)                                  │
│  ↳...                                                                          │
│                                                                                │
│  ↳ (same file)                                                                 │
│    7 │$(t+1)                                                                   │
│      │  ^^^                                                                    │
╰────────────────────────────────────────────────────────────────────────────────╯
/// End