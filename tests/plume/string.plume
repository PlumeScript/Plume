/// Test index string 1
$("abc").upper()
/// Output
ABC
/// End

/// Test index string 2
let x = abc
$x.upper()
/// Output
ABC
/// End

/// Test index string 3
$String.upper(abc)
/// Output
ABC
/// End

/// Test trim
---
$(" a ").trim()
---
/// Output
---a---
/// End

/// Test rtrim
---
$(" a ").rtrim()
---
/// Output
---a ---
/// End

/// Test ltrim
---
$(" a ").ltrim()
---
/// Output
--- a---
/// End

/// Test dedent
let x = raw[
	if true
		if false
			run $nothing()
		end
	end
]end
---\n
$x.dedent()\n
---
/// Output
---
if true
	if false
		run $nothing()
	end
end
---
/// End

/// Test indent 1
let x = raw[
if true
	if false
		run $nothing()
	end
end
]end
---\n
$x.indent()\n
---
/// Output
---
	if true
		if false
			run $nothing()
		end
	end
---
/// End

/// Test indent 2
let x = raw[
if true
	if false
		run $nothing()
	end
end
]end
---\n
$x.indent(sep:>)\n
---
/// Output
---
>if true
>	if false
>		run $nothing()
>	end
>end
---
/// End

/// Test collapse
---
$("a  a  	  a").collapse()
---
/// Output
---a a a---
/// End

/// Test upper
$("az5AB").upper()
/// Output
AZ5AB
/// End

/// Test lower
$("az5AB").lower()
/// Output
az5ab
/// End

/// Test replace 1
$("aza5").replace(a, 5)
/// Output
5z55
/// End

/// Test replace 2
$("aza5").replace(%w, 5, ?rich)
/// Output
5555
/// End