/// Test simple context
with local: fr
  Voici un nombre: $(6543.56)
end
/// Output
Voici un nombre: 6 543,56
/// End

/// Test nested context
with local: fr
  with local: en
    Here is a number: $(6543.56)
  end
end
/// Output
Here is a number: 6,543.56
/// End

/// Test default context
with local: fr
  with local: none
    Voici un nombre: $(6543.56)
  end
end
/// Output
Voici un nombre: 6543.56
/// End

/// Test context from file
with local: fr
  $import(tests/plume/toimport/numbers)
end
/// Output
x = 654 237,458 9
/// End
